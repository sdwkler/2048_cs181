    style T2 fill:#e0e7ef,stroke:#7a8faa,color:#3a4f6a
    style T3 fill:#f0ebe0,stroke:#b8a878,color:#6e5a30
    style M1 fill:#e3efe0,stroke:#8aaa8a,stroke-width:2px,color:#2d4a2d
    style M2 fill:#e0e7ef,stroke:#7a8faa,stroke-width:2px,color:#2d3f5a
    style M3 fill:#f0ebe0,stroke:#b8a878,stroke-width:2px,color:#4a3a20